---
import type { CollectionEntry } from 'astro:content';

export interface Props {
  posts: CollectionEntry<'posts'>[];
}

const { posts } = Astro.props;
---
<section class="top-stories" data-top-stories>
  <div class="top-stories-head">
    <div class="rule-l"></div>
    <div class="kicker">The Day's Big Stories</div>
    <div class="rule-l"></div>
    <div class="ts-pos" data-ts-pos>1 / {posts.length}</div>
  </div>

  <div class="ts-viewport" data-ts-viewport>
    <div class="ts-track" data-ts-track>
      {posts.map((p, i) => (
        <article class="ts-slide" data-ts-slide data-post-id={p.data.id}>
          <div class="ts-meta">
            <span class="ts-num">{String(i + 1).padStart(2, '0')}</span>
            <span class={'ts-fmt' + (p.data.type === 'carousel' ? ' carousel' : '')}>
              {p.data.type === 'carousel' ? `Carousel · ${(p.data.slides ?? []).length} slides` : 'Brief'}
            </span>
            <span class="ts-src">{p.data.source.outlet}</span>
          </div>
          <h3 class="ts-headline">
            <a href={`/posts/${p.slug}`} style="color: inherit; text-decoration: none;">{p.data.headline}</a>
          </h3>
          <button class="ts-mark-read" type="button" data-ts-mark-read data-post-id={p.data.id}>Mark read &amp; hide</button>
        </article>
      ))}
    </div>
  </div>

  <div class="ts-dots" data-ts-dots>
    {posts.map((_, i) => (
      <button class={'ts-dot' + (i === 0 ? ' active' : '')} data-ts-dot data-index={i} aria-label={`Story ${i + 1}`}></button>
    ))}
  </div>
</section>

<div class="ts-empty" data-ts-empty hidden>
  <p>You've read all the day's big stories.</p>
  <button class="ts-reset" data-ts-reset>Reset read history</button>
</div>
