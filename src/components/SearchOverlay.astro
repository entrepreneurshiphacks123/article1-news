---
// Minimal client-side search modal. Intentionally simple — fuzzy on headline + tags.
import { getCollection } from 'astro:content';
const posts = await getCollection('posts');
const index = posts.map((p) => ({
  id: p.data.id,
  slug: p.slug,
  headline: p.data.headline,
  tags: p.data.tags,
  type: p.data.type,
  outlet: p.data.source.outlet,
}));
const json = JSON.stringify(index);
---
<div class="search-overlay" data-search-overlay hidden>
  <div class="search-sheet">
    <div class="search-bar">
      <input type="search" placeholder="Search the archive" data-search-input autocomplete="off" autofocus />
      <button class="search-close" type="button" data-search-close>Esc</button>
    </div>
    <div class="search-results" data-search-results></div>
  </div>
</div>

<script is:inline define:vars={{ json }}>
(function () {
  const overlay = document.querySelector('[data-search-overlay]');
  const trigger = document.querySelector('[data-search-trigger]');
  const closeBtn = document.querySelector('[data-search-close]');
  const input = document.querySelector('[data-search-input]');
  const results = document.querySelector('[data-search-results]');
  if (!overlay || !trigger) return;

  const index = JSON.parse(json);

  const open = () => {
    overlay.hidden = false;
    document.body.style.overflow = 'hidden';
    setTimeout(() => input?.focus(), 50);
    render('');
  };
  const close = () => {
    overlay.hidden = true;
    document.body.style.overflow = '';
    if (input) input.value = '';
  };

  const render = (q) => {
    const query = q.trim().toLowerCase();
    const items = !query
      ? index.slice(0, 12)
      : index.filter((p) =>
          p.headline.toLowerCase().includes(query) ||
          p.tags.some((t) => t.toLowerCase().includes(query)) ||
          p.outlet.toLowerCase().includes(query)
        );
    results.innerHTML = items.length === 0
      ? '<div class="search-empty">No results.</div>'
      : items
          .map(
            (p) => `
            <a class="search-result" href="/posts/${p.slug}">
              <div class="search-result-meta">${p.type === 'carousel' ? 'Carousel' : 'Brief'} · ${p.outlet}</div>
              <div class="search-result-headline">${p.headline}</div>
            </a>
          `,
          )
          .join('');
  };

  trigger.addEventListener('click', open);
  closeBtn?.addEventListener('click', close);
  overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
  input?.addEventListener('input', (e) => render(e.target.value));
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') close();
    else if ((e.key === 'k' || e.key === 'K') && (e.metaKey || e.ctrlKey)) {
      e.preventDefault();
      open();
    }
  });
})();
</script>

<style>
  .search-overlay[hidden] { display: none !important; }
  .search-overlay {
    position: fixed;
    inset: 0;
    background: rgba(26, 26, 26, 0.4);
    z-index: 1100;
    display: flex;
    justify-content: center;
    padding: 80px 20px 20px;
  }
  .search-sheet {
    background: var(--parchment);
    width: 100%;
    max-width: 640px;
    border: 1px solid var(--hairline);
    align-self: flex-start;
  }
  .search-bar {
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--hairline);
  }
  .search-bar input {
    flex: 1;
    padding: 18px 20px;
    border: 0;
    background: transparent;
    font-family: var(--serif);
    font-size: 22px;
    color: var(--ink);
    outline: none;
  }
  .search-close {
    border: 1px solid var(--hairline);
    background: transparent;
    padding: 6px 10px;
    margin-right: 14px;
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    cursor: pointer;
  }
  .search-results {
    max-height: 70vh;
    overflow-y: auto;
  }
  .search-result {
    display: block;
    padding: 14px 20px;
    border-bottom: 1px solid var(--hairline);
    text-decoration: none;
    color: inherit;
  }
  .search-result:hover {
    background: var(--parchment-2);
  }
  .search-result-meta {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 4px;
  }
  .search-result-headline {
    font-family: var(--serif);
    font-size: 18px;
    line-height: 1.3;
    color: var(--ink);
  }
  .search-empty {
    padding: 40px 20px;
    text-align: center;
    font-family: var(--serif);
    font-style: italic;
    color: var(--ink-2);
  }
</style>
