---
import BrandMark from './BrandMark.astro';

export interface Props {
  // active props retained for backwards-compat but no longer rendered in header
  active?: string;
  activeRace?: string;
}
---
<header class="site-header" style="padding-bottom: 28px;">
  <div class="top">
    <div>
      <a href="/" style="text-decoration: none;">
        <BrandMark />
      </a>
      <div class="tagline">American politics through the lens of the Constitution and the long memory.</div>
    </div>
    <div class="icons">
      <button class="icon-btn refresh-btn" type="button" aria-label="Refresh feed" data-refresh-trigger>
        <svg class="refresh-icon" width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="23 4 23 10 17 10" />
          <polyline points="1 20 1 14 7 14" />
          <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" />
        </svg>
      </button>
      <a class="icon-btn" href="/rss.xml" aria-label="RSS">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M4 11a9 9 0 0 1 9 9" />
          <path d="M4 4a16 16 0 0 1 16 16" />
          <circle cx="5" cy="19" r="1.5" fill="currentColor" />
        </svg>
      </a>
      <button class="icon-btn" type="button" aria-label="Search" data-search-trigger>
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7" />
          <path d="m20 20-3.5-3.5" />
        </svg>
      </button>
    </div>
  </div>
</header>

<style>
  /* Refresh button — spin animation on click, idle hover lifts color to navy. */
  .refresh-btn .refresh-icon {
    transition: transform 0.2s ease, color 0.15s ease;
    transform-origin: 50% 50%;
  }
  .refresh-btn:hover .refresh-icon {
    transform: rotate(-22deg);
  }
  .refresh-btn.is-spinning .refresh-icon {
    animation: refresh-spin 0.7s cubic-bezier(0.5, 0, 0.2, 1) 1;
    transform-origin: 50% 50%;
  }
  /* While spinning, lock the click so users can't double-fire. */
  .refresh-btn.is-spinning {
    pointer-events: none;
    color: var(--navy);
  }
  @keyframes refresh-spin {
    0%   { transform: rotate(0deg); }
    100% { transform: rotate(-360deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .refresh-btn.is-spinning .refresh-icon { animation: none; }
    .refresh-btn:hover .refresh-icon { transform: none; }
  }
</style>

<script>
  // Spin the icon, then reload. The spin runs while the network fetch starts —
  // by the time the user perceives the spin completing, the new page is in.
  const btn = document.querySelector('[data-refresh-trigger]');
  if (btn) {
    btn.addEventListener('click', () => {
      btn.classList.add('is-spinning');
      // Kick the reload immediately; the spin animation overlaps the navigation.
      // 350ms matches the visual midpoint of the 0.7s spin so the page swap
      // feels like the spin "loaded" something rather than reset to a blank state.
      setTimeout(() => {
        location.reload();
      }, 350);
    });
  }
</script>
