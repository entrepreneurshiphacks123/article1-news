---
import MetaBottom from './MetaBottom.astro';
import { fmtRelative } from '../lib/topics';
import type { CollectionEntry } from 'astro:content';

export interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const n = post.data.numbers;
const relative = fmtRelative(post.data.date);
---
<article class="card numbers-card" data-post-card data-post-id={post.data.id} data-post-slug={post.slug}>
  <div class="card-meta-top">
    <span class="format-tag numbers">Numbers of the Day</span>
    <span class="dot"></span>
    <span>{relative}</span>
  </div>

  {n && (
    <a href={`/posts/${post.slug}`} class="numbers-link">
      <div class="numbers-value">{n.value}</div>
      {n.unit && <div class="numbers-unit">{n.unit}</div>}
      <p class="numbers-body">{n.body}</p>
    </a>
  )}

  <MetaBottom outlet={post.data.source.outlet} tags={post.data.tags} />
</article>

<style>
  .numbers-card { padding-top: 32px; }
  .numbers-link { display: block; text-decoration: none; color: inherit; }
  .numbers-value {
    font-family: var(--serif);
    font-style: italic;
    font-weight: 700;
    color: var(--red);
    font-size: 88px;
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin: 12px 0 4px;
  }
  .numbers-unit {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--ink-3);
    margin-bottom: 18px;
  }
  .numbers-body {
    font-family: var(--serif);
    font-size: 19px;
    line-height: 1.5;
    color: var(--ink);
    margin: 0 0 22px;
    text-wrap: pretty;
  }
  .format-tag.numbers { color: var(--navy); font-weight: 600; }

  @media (min-width: 720px) {
    .numbers-value { font-size: 120px; }
  }
</style>
