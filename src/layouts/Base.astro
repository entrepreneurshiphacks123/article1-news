---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  ogType?: 'website' | 'article';
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'American politics through the lens of the Constitution and the long memory.',
  canonical,
  ogType = 'website',
  jsonLd,
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).toString();

// Site-wide Organization schema (always present). Per-page schemas merge in via the jsonLd prop.
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'NewsMediaOrganization',
  '@id': 'https://article1.news#organization',
  name: 'Article I',
  alternateName: 'Article 1',
  url: 'https://article1.news',
  description: 'American politics through the lens of the Constitution and the long memory.',
  logo: {
    '@type': 'ImageObject',
    url: 'https://article1.news/favicon.svg',
  },
  publishingPrinciples: 'https://article1.news/about',
  diversityPolicy: 'https://article1.news/about',
  ethicsPolicy: 'https://article1.news/about',
};

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': 'https://article1.news#website',
  name: 'Article I',
  url: 'https://article1.news',
  description: 'American politics through the lens of the Constitution and the long memory.',
  publisher: { '@id': 'https://article1.news#organization' },
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://article1.news/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};

const allSchemas = [
  orgSchema,
  websiteSchema,
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="alternate" type="application/rss+xml" title="Article I" href="/rss.xml" />

  <!-- Google Search Console verification — set once GSC gives the meta tag content -->
  <!-- <meta name="google-site-verification" content="REPLACE_WITH_GSC_TOKEN" /> -->

  <meta property="og:type" content={ogType} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:site_name" content="Article I" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Source+Serif+4:ital,opsz,wght@0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,600;1,8..60,700&family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />

  {allSchemas.map((schema) => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <slot name="head" />
</head>
<body>
  <slot />
</body>
</html>
