---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RenderCard from '../components/RenderCard.astro';
import TopStories from '../components/TopStories.astro';
import Fleuron from '../components/Fleuron.astro';
import Carousels from '../components/Carousels.client.astro';
import SearchOverlay from '../components/SearchOverlay.astro';
import ShowMore from '../components/ShowMore.astro';
import { paginate, INITIAL_VISIBLE } from '../lib/feed';

const posts = await getCollection('posts');
const sorted = [...posts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Top Stories rail: today's most recent NEWS items.
// - Exclude cartoons (visual breaks, not news of the day).
// - Drop the "promote all carousels" rule — a carousel can be a top story
//   only if it's recent and news-anchored, judged the same way as briefs.
// - Limit to last 36h so the rail rotates as the day progresses.
const TOP_STORIES_WINDOW_MS = 36 * 60 * 60 * 1000;
const now = Date.now();
const topStories = sorted
  .filter((p) => p.data.type !== 'cartoon')
  .filter((p) => now - p.data.date.getTime() < TOP_STORIES_WINDOW_MS)
  .slice(0, 5);

const { page: pageItems, hasNext } = paginate(sorted, 1);
const nextPageHref = hasNext ? '/page/2' : null;
---
<Base title="Article I — American politics through the lens of the Constitution and the long memory.">
  <div style="background: var(--parchment); min-height: 100%;">
    <Header active="All" />

    <div class="feed">
      {topStories.length > 0 && <TopStories posts={topStories} />}

      <div class="feed-sep" style="padding: 40px 0 12px;">
        <span class="rule"></span>
      </div>

      <div data-feed>
        {pageItems.map((p, i) => {
          const isLede = i === 0 && p.data.type === 'static';
          const hiddenClass = i >= INITIAL_VISIBLE ? ' is-hidden' : '';
          const showFleuron = i > 0 && (i + 1) % 5 === 0 && i < pageItems.length - 1;
          return (
            <>
              <div class={'card-slot' + hiddenClass} data-card>
                <RenderCard post={p} lede={isLede} />
              </div>
              {showFleuron && <div class={'card-slot' + hiddenClass} data-card><Fleuron /></div>}
            </>
          );
        })}
      </div>

      <ShowMore nextPageHref={nextPageHref} />
    </div>

    <Footer activeRace="all" />
  </div>

  <SearchOverlay />
  <Carousels />
</Base>
