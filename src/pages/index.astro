---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import StaticCard from '../components/StaticCard.astro';
import CarouselCard from '../components/CarouselCard.astro';
import TopStories from '../components/TopStories.astro';
import Fleuron from '../components/Fleuron.astro';
import Carousels from '../components/Carousels.client.astro';
import SearchOverlay from '../components/SearchOverlay.astro';

const posts = await getCollection('posts');
const sorted = [...posts].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// Top stories: prefer carousels, fill rest with most recent briefs, max 5
const carousels = sorted.filter((p) => p.data.type === 'carousel');
const briefs = sorted.filter((p) => p.data.type === 'static');
const topStories = [...carousels, ...briefs.slice(0, Math.max(0, 5 - carousels.length))].slice(0, 5);
---
<Base title="Article I — American politics through the lens of the Constitution and the long memory.">
  <div style="background: var(--parchment); min-height: 100%;">
    <Header active="All" />

    <div class="feed">
      {topStories.length > 0 && <TopStories posts={topStories} />}

      <div class="feed-sep" style="padding: 40px 0 12px;">
        <span class="rule"></span>
      </div>

      {sorted.map((p, i) => {
        const isLede = i === 0 && p.data.type === 'static';
        const card = p.data.type === 'carousel'
          ? <CarouselCard post={p} />
          : <StaticCard post={p} lede={isLede} />;
        const showFleuron = i > 0 && (i + 1) % 5 === 0 && i < sorted.length - 1;
        return (
          <>
            {card}
            {showFleuron && <Fleuron />}
          </>
        );
      })}
    </div>

    <Footer active="All" activeRace="all" />
  </div>

  <SearchOverlay />
  <Carousels />
</Base>
