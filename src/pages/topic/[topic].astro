---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import RenderCard from '../../components/RenderCard.astro';
import Fleuron from '../../components/Fleuron.astro';
import Carousels from '../../components/Carousels.client.astro';
import SearchOverlay from '../../components/SearchOverlay.astro';
import ShowMore from '../../components/ShowMore.astro';
import { INITIAL_VISIBLE } from '../../lib/feed';
export async function getStaticPaths() {
  const allPosts = await getCollection('posts');
  const tagSet = new Set<string>();
  for (const p of allPosts) for (const t of p.data.tags) tagSet.add(t);
  return Array.from(tagSet).map((tag) => ({
    params: { topic: tag },
    props: { topic: { label: tag } },
  }));
}

const { topic } = Astro.props as { topic: { label: string } };
const allPosts = await getCollection('posts');
const filtered = allPosts
  .filter((p) => p.data.tags.includes(topic.label))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---
<Base
  title={`${topic.label} — Article I`}
  description={`Article I coverage filtered by ${topic.label}.`}
>
  <div style="background: var(--parchment); min-height: 100%;">
    <Header active={topic.label} />

    <div class="feed">
      <div class="feed-sep">
        <span class="rule"></span>
        <span class="label">{topic.label} · {filtered.length} {filtered.length === 1 ? 'post' : 'posts'}</span>
        <span class="rule"></span>
      </div>

      {filtered.length === 0 ? (
        <div class="ts-empty">
          <p>No posts in this topic yet.</p>
        </div>
      ) : (
        <>
          <div data-feed>
            {filtered.map((p, i) => {
              const isLede = i === 0 && p.data.type === 'static';
              const hiddenClass = i >= INITIAL_VISIBLE ? ' is-hidden' : '';
              const showFleuron = i > 0 && (i + 1) % 5 === 0 && i < filtered.length - 1;
              return (
                <>
                  <div class={'card-slot' + hiddenClass} data-card>
                    <RenderCard post={p} lede={isLede} />
                  </div>
                  {showFleuron && <div class={'card-slot' + hiddenClass} data-card><Fleuron /></div>}
                </>
              );
            })}
          </div>
          {filtered.length > INITIAL_VISIBLE && <ShowMore />}
        </>
      )}
    </div>

    <Footer activeRace="all" />
  </div>

  <SearchOverlay />
  <Carousels />
</Base>
